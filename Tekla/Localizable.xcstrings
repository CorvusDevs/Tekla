    "Accessibility permission required. Click to open System Settings and enable Tekla." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilgængelighedstilladelse kræves. Klik for at åbne Systemindstillinger og aktivere Tekla."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bedienungshilfen-Berechtigung erforderlich. Klicken Sie, um die Systemeinstellungen zu öffnen und Tekla zu aktivieren."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se requiere permiso de accesibilidad. Haz clic para abrir Ajustes del Sistema y activar Tekla."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esteettömyysoikeus vaaditaan. Avaa Järjestelmäasetukset ja ota Tekla käyttöön napsauttamalla."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Autorisation d'accessibilité requise. Cliquez pour ouvrir les Réglages Système et activer Tekla."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permesso di accessibilità richiesto. Fai clic per aprire Impostazioni di Sistema e attivare Tekla."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tilgjengelighetssamtykke kreves. Klikk for å åpne Systeminnstillinger og aktivere Tekla."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toegankelijkheidstoestemming vereist. Klik om Systeeminstellingen te openen en Tekla in te schakelen."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wymagane uprawnienie dostępności. Kliknij, aby otworzyć Ustawienia systemu i włączyć Teklę."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Permissão de acessibilidade necessária. Clique para abrir os Ajustes do Sistema e ativar Tekla."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Требуется разрешение на управление. Нажмите, чтобы открыть Системные настройки и включить Tekla."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tillgänglighetsbehörighet krävs. Klicka för att öppna Systeminställningar och aktivera Tekla."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erişilebilirlik izni gerekli. Sistem Ayarları'nı açmak ve Tekla'yı etkinleştirmek için tıklayın."
          }
        }
      }
    },

    "Tekla learns which words you use most often to improve predictions. All data stays on your device." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla lærer hvilke ord du bruger oftest for at forbedre forslag. Alle data forbliver på din enhed."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla lernt, welche Wörter Sie am häufigsten verwenden, um Vorschläge zu verbessern. Alle Daten bleiben auf Ihrem Gerät."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla aprende qué palabras usas con más frecuencia para mejorar las predicciones. Todos los datos permanecen en tu dispositivo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla oppii, mitä sanoja käytät useimmin parantaakseen ehdotuksia. Kaikki tiedot pysyvät laitteellasi."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla apprend les mots que vous utilisez le plus souvent pour améliorer les prédictions. Toutes les données restent sur votre appareil."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla impara quali parole usi più spesso per migliorare i suggerimenti. Tutti i dati restano sul tuo dispositivo."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla lærer hvilke ord du bruker oftest for å forbedre forslag. Alle data forblir på enheten din."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla leert welke woorden u het vaakst gebruikt om voorspellingen te verbeteren. Alle gegevens blijven op uw apparaat."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla uczy się, których słów używasz najczęściej, aby poprawić podpowiedzi. Wszystkie dane pozostają na Twoim urządzeniu."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla aprende quais palavras você usa com mais frequência para melhorar as previsões. Todos os dados permanecem no seu dispositivo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla запоминает, какие слова вы используете чаще всего, чтобы улучшить подсказки. Все данные остаются на вашем устройстве."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla lär sig vilka ord du använder oftast för att förbättra förslag. All data stannar på din enhet."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tekla, tahminleri iyileştirmek için en sık kullandığınız kelimeleri öğrenir. Tüm veriler cihazınızda kalır."
          }
        }
      }
    },
    "This will remove all words Tekla has learned from your typing. Predictions will reset to defaults." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette fjerner alle ord som Tekla har lært. Forslag nulstilles til standardværdier."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dadurch werden alle von Tekla gelernten Wörter entfernt. Vorschläge werden auf die Standardwerte zurückgesetzt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto eliminará todas las palabras que Tekla ha aprendido de tu escritura. Las predicciones se restablecerán a los valores predeterminados."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tämä poistaa kaikki Teklan oppimat sanat. Ehdotukset palautetaan oletusarvoihin."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela supprimera tous les mots appris par Tekla. Les prédictions seront réinitialisées par défaut."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verranno rimosse tutte le parole imparate da Tekla. I suggerimenti torneranno ai valori predefiniti."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dette fjerner alle ord Tekla har lært. Forslag tilbakestilles til standardverdier."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dit verwijdert alle woorden die Tekla heeft geleerd. Voorspellingen worden teruggezet naar standaard."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Spowoduje to usunięcie wszystkich słów nauczonych przez Teklę. Podpowiedzi zostaną zresetowane do domyślnych."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isto removerá todas as palavras que Tekla aprendeu. As previsões serão redefinidas para os padrões."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Будут удалены все слова, которые Tekla выучила. Подсказки вернутся к значениям по умолчанию."
          }
        },
        "sv" : {

    "Changes the prediction language and keyboard layout where applicable (e.g., AZERTY for French, QWERTZ for German)." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ændrer forslagssproget og tastaturlayoutet hvor det er relevant (f.eks. AZERTY for fransk, QWERTZ for tysk)."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändert die Vorhersagesprache und das Tastaturlayout (z. B. AZERTY für Französisch, QWERTZ für Deutsch)."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia el idioma de predicción y la disposición del teclado según corresponda (p. ej., AZERTY para francés, QWERTZ para alemán)."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vaihtaa ehdotuskielen ja näppäimistöasettelun tarvittaessa (esim. AZERTY ranskalle, QWERTZ saksalle)."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Change la langue de prédiction et la disposition du clavier selon les cas (ex. AZERTY pour le français, QWERTZ pour l'allemand)."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cambia la lingua dei suggerimenti e il layout della tastiera dove applicabile (es. AZERTY per il francese, QWERTZ per il tedesco)."
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Endrer forslagsspråk og tastaturoppsett der det er aktuelt (f.eks. AZERTY for fransk, QWERTZ for tysk)."
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wijzigt de voorspellingstaal en toetsenbordindeling waar van toepassing (bijv. AZERTY voor Frans, QWERTZ voor Duits)."
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Zmienia język podpowiedzi i układ klawiatury w stosownych przypadkach (np. AZERTY dla francuskiego, QWERTZ dla niemieckiego)."
          }
        },
        "pt" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Altera o idioma de previsão e a disposição do teclado onde aplicável (ex.: AZERTY para francês, QWERTZ para alemão)."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Изменяет язык подсказок и раскладку клавиатуры при необходимости (например, AZERTY для французского, QWERTZ для немецкого)."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ändrar språk för förslag och tangentbordslayout där det är tillämpligt (t.ex. AZERTY för franska, QWERTZ för tyska)."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Uygun durumlarda tahmin dilini ve klavye düzenini değiştirir (ör. Fransızca için AZERTY, Almanca için QWERTZ)."
          }
        }
      }
    },
